# Local env / secrets
.env
.env.local

# Firebase per-project config (generated by `flutterfire configure`).
# Contains the public Firebase client API key — safe by design, but kept out of
# the repo to avoid secret-scanner noise. Regenerate with `flutterfire configure`.
app/lib/firebase_options.dart
app/android/app/google-services.json
app/ios/Runner/GoogleService-Info.plist
.firebase/
firebase/functions/node_modules/
firebase/rules-tests/node_modules/

# Emulator debug logs (generated by emulators:exec)
firebase/*-debug.log
firebase/**/*-debug.log

# Built artifacts / build logs (don't commit binaries)
*.apk
app/build_apk*.log

# One-off local admin helpers (read your firebase login; not for the repo)
enable_phone.js
approve_volunteer.js
make_admin.js
