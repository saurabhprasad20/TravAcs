rules_version = '2';

// TravAcs Firestore Security Rules (design §5.2). Default-deny: any path not
// matched is denied. Protected fields (role, verificationStatus, ratings,
// volunteerId, amounts, otpHash) are NOT client-writable except the single
// guarded FCFS "accept" transition; everything else is done by Cloud Functions
// (Admin SDK, which bypasses these rules).
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    function profileData(uid) {
      return get(/databases/$(database)/documents/profiles/$(uid)).data;
    }
    function isApprovedVolunteer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && profileData(request.auth.uid).role == 'volunteer'
        && profileData(request.auth.uid).verificationStatus == 'approved'
        && profileData(request.auth.uid).isActive == true;
    }
    // The caller's (TravAcser's) service city, or '' if unset.
    function myCity() {
      return profileData(request.auth.uid).get('serviceCity', '');
    }
    function requestData(requestId) {
      return get(/databases/$(database)/documents/requests/$(requestId)).data;
    }

    // ---- profiles ---------------------------------------------------------
    match /profiles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Create your own profile. Role is set once and must be a normal role;
      // server-managed fields must start at their initial values.
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role in ['requester', 'volunteer']
        && request.resource.data.ratingAvg == 0
        && request.resource.data.ratingCount == 0
        && (request.resource.data.role != 'volunteer'
            || request.resource.data.verificationStatus == 'pending');

      // Update your own profile but never the protected fields.
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.ratingAvg == resource.data.ratingAvg
        && request.resource.data.ratingCount == resource.data.ratingCount
        && request.resource.data.get('verificationStatus', 'pending')
             == resource.data.get('verificationStatus', 'pending')
        && request.resource.data.get('rejectionReason', '')
             == resource.data.get('rejectionReason', '');

      allow delete: if false;
    }

    // ---- requests ---------------------------------------------------------
    match /requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.requesterId == request.auth.uid
        || resource.data.volunteerId == request.auth.uid
        // Region-scoped: an approved TravAcser sees open requests only in their
        // own city.
        || (resource.data.status == 'broadcast'
            && isApprovedVolunteer()
            && resource.data.serviceCity == myCity()
            // A strict same-gender request is only readable by matching-gender
            // TravAcsers until it widens to all genders.
            && (resource.data.get('genderRestricted', false) == false
                || resource.data.get('genderWidened', false) == true
                || resource.data.get('requesterGender', '')
                     == profileData(request.auth.uid).get('gender', '')))
        || isAdmin()
      );

      allow create: if isSignedIn()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status in ['draft', 'broadcast']
        && request.resource.data.volunteerId == null
        && request.resource.data.serviceCity is string
        // Server-managed slot counter must start empty — otherwise a crafted
        // client could pre-set acceptedCount (even negative) and let extra
        // TravAcsers over-subscribe the request.
        && request.resource.data.get('acceptedCount', 0) == 0
        && request.resource.data.numTravAcsers is int
        && request.resource.data.numTravAcsers >= 1
        && request.resource.data.numTravAcsers <= 10
        && request.resource.data.numTravellers is int
        && request.resource.data.numTravellers >= 1
        && request.resource.data.numTravellers <= 10
        // A client cannot pre-widen a gender-restricted request.
        && request.resource.data.get('genderWidened', false) == false;

      // The requester may only CANCEL, and only before anyone accepts. Accept,
      // start, complete and payment transitions are done by Cloud Functions
      // (Admin SDK), never by clients.
      allow update: if resource.data.requesterId == request.auth.uid
        && resource.data.status in ['draft', 'broadcast']
        && resource.data.get('acceptedCount', 0) == 0
        && request.resource.data.status == 'cancelled';

      allow delete: if false;

      // Per-TravAcser acceptance records — written only by Cloud Functions;
      // readable by that TravAcser and the request's requester (per-request,
      // direct-path reads). Collection-group reads are covered by the
      // top-level rule below.
      match /assignments/{vid} {
        allow read: if isSignedIn() && (
          vid == request.auth.uid
          || requestData(requestId).requesterId == request.auth.uid
          || isAdmin()
        );
        allow write: if false;
      }
    }

    // Collection-group rule so a TravAcser can list THEIR OWN assignments via
    // `collectionGroup('assignments')`, and a requester can list the assignments
    // across THEIR OWN requests (to detect unpaid dues). It must gate on FIELDS
    // the query filters on (`volunteerId` / `requesterId`) — during a list the
    // path wildcard `vid` is null, so a doc-id check would error.
    match /{path=**}/assignments/{vid} {
      allow read: if isSignedIn()
        && (resource.data.volunteerId == request.auth.uid
            || resource.data.requesterId == request.auth.uid);
      allow write: if false;
    }

    // ---- trips (id == requestId) -----------------------------------------
    match /trips/{requestId} {
      allow read: if isSignedIn() && (
        requestData(requestId).requesterId == request.auth.uid
        || requestData(requestId).volunteerId == request.auth.uid
        || isAdmin()
      );
      // Trips are created/updated only by Cloud Functions.
      allow write: if false;
    }

    // ---- ratings (id == {requestId}_{raterRole}) -------------------------
    // Ratings are written server-side by `submitRating` (onto the assignment +
    // the ratee's profile aggregate); clients never create them directly, so a
    // spammed/forged rating can't inflate a rating average.
    match /ratings/{ratingId} {
      allow read: if isSignedIn() && (
        resource.data.raterId == request.auth.uid
        || resource.data.rateeId == request.auth.uid
        || isAdmin()
      );
      allow write: if false;
    }

    // ---- tripLogs (admin telemetry: app + manually-booked trips) ---------
    match /tripLogs/{id} {
      allow read: if isAdmin();
      // Written only by Cloud Functions (Admin SDK).
      allow write: if false;
    }

    // ---- devices (FCM tokens) --------------------------------------------
    match /devices/{uid}/tokens/{token} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
