# Copy this file to `run.ps1` (gitignored) and fill in your values, then:
#   ./run.ps1
# These values are public-by-design (the publishable key is meant to ship in
# the client); RLS protects the data. They are kept out of source for hygiene.

$Url = "https://YOUR-PROJECT-ref.supabase.co"
$Key = "sb_publishable_xxxxxxxxxxxxxxxxxxxx"

flutter run `
  --dart-define=SUPABASE_URL=$Url `
  --dart-define=SUPABASE_ANON_KEY=$Key
